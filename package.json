{
  "name": "epic-frontend",
  "version": "1.0.0",
  "type": "module",
  "description": "React-based Frontend for Epic Religious Guidance Application",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && vite build",
    "dev": "vite",
