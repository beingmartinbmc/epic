  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "jsdom": "^25.0.0",
    "vite": "^8.0.10",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.0.0",
    "bootstrap": "^5.3.0",
    "franc-all": "^7.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "keywords": [
    "react",
    "frontend",
    "religious",
    "spiritual",
